    "agents": {
        "defaults": {
            "model": {
                "primary": "gradient/openai-gpt-5.2"
            },
            "models": {
                "gradient/openai-gpt-oss-120b": {},
                "gradient/openai-gpt-5-mini": {},
                "gradient/openai-gpt-5-nano": {},
                "gradient/anthropic-claude-opus-4.6": {},
                "gradient/anthropic-claude-haiku-4.5": {},
                "gradient/anthropic-claude-4.6-sonnet": {}
            },
            "memorySearch": {
                "enabled": true,
                "provider": "gemini",
                "model": "gemini-embedding-001"
            },
            "compaction": {
                "mode": "safeguard",
                "memoryFlush": {
                    "enabled": true
                }
            },
            "heartbeat": {
                "model": "gradient/anthropic-claude-haiku-4.5"
            },
            "sandbox": {
                "mode": "off"
            }
        }
    },
    "tools": {
        "deny": [],
        "agentToAgent": {
            "allow": []
        }
    },
    "commands": {
        "native": "auto",
        "nativeSkills": "auto",
        "restart": true
    },
    "web": {
        "enabled": false
    },
    "channels": {
        "telegram": {
            "enabled": false,
            "dmPolicy": "pairing",
            "replyToMode": "all",
            "groupPolicy": "allowlist",
            "streamMode": "partial",
            "actions": {
                "sendMessage": true,
                "sticker": true
            }
        },
        "whatsapp": {
            "enabled": false
        }
    },
    "memory": {
        "backend": "builtin",
        "citations": "on"
    },
    "skills": {
        "entries": {
            "healthcheck": {
                "enabled": true
            }
        }
    },
    "plugins": {
        "enabled": true,
        "allow": [
            "telegram",
            "whatsapp",
            "signal",
            "discord",
            "slack",
            "memory",
            "google-drive",
            "google-calendar",
            "gmail"
        ],
        "entries": {
            "whatsapp": {
                "enabled": true
            },
            "telegram": {
                "enabled": true
            },
            "signal": {
                "enabled": true
            },
            "discord": {
                "enabled": true
            },
            "slack": {
                "enabled": true,
                "mode": "socket",
                "botToken": "${SLACK_BOT_TOKEN}",
                "appToken": "${SLACK_APP_TOKEN}",
                "signingSecret": "${SLACK_SIGNING_SECRET}"
            },
            "memory": {
                "enabled": true,
                "journalPath": "${OPENCLAW_STATE_DIR}/memory",
                "fileFormat": "DD-MM-YYYY",
                "autoWrite": true,
                "includeMetadata": true
            },
            "google-drive": {
                "enabled": true,
                "credentials": "${GOOGLE_CREDENTIALS_PATH}",
                "scopes": [
                    "https://www.googleapis.com/auth/drive.file",
                    "https://www.googleapis.com/auth/drive.readonly"
                ]
            },
            "google-calendar": {
                "enabled": true,
                "credentials": "${GOOGLE_CREDENTIALS_PATH}",
                "scopes": [
                    "https://www.googleapis.com/auth/calendar",
                    "https://www.googleapis.com/auth/calendar.events"
                ]
            },
            "gmail": {
                "enabled": true,
                "credentials": "${GOOGLE_CREDENTIALS_PATH}",
                "scopes": [
                    "https://www.googleapis.com/auth/gmail.readonly",
                    "https://www.googleapis.com/auth/gmail.compose"
                ]
            }
        }
    }
}